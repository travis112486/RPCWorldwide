# =============================================================================
# RPC Worldwide — Environment Variables Reference
# =============================================================================
# This file is committed to the repo as a reference template.
# It lists every env var the project uses with safe placeholder values.
#
# To set up a new environment:
#   1. Copy this file:  cp .env.example .env.local
#   2. Replace every YOUR_VALUE_HERE with real credentials.
#   3. Never commit .env.local
#
# Full setup guide: docs/local-dev.md
# =============================================================================


# --- PUBLIC (browser-safe) ---------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=YOUR_VALUE_HERE
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_VALUE_HERE
NEXT_PUBLIC_APP_URL=http://localhost:3000


# --- SERVER-ONLY (never expose to the browser) --------------------------------

SUPABASE_SERVICE_ROLE_KEY=YOUR_VALUE_HERE

EMAIL_PROVIDER=resend
RESEND_API_KEY=YOUR_VALUE_HERE
# SENDGRID_API_KEY=YOUR_VALUE_HERE

EMAIL_FROM=notifications@rpcworldwide.com
EMAIL_FROM_NAME=RPC Worldwide


# --- SENTRY (error monitoring) ------------------------------------------------

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
